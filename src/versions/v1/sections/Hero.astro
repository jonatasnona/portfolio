---
import type { Locale } from '../../../site.config';
import type { PortfolioContent } from '../../../content/types';
import { assetPath } from '../../../lib/paths';
import { siteConfig } from '../../../site.config';

type Props = {
	content: PortfolioContent;
	locale: Locale;
};

const { content, locale } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
	<div class="shell hero-grid">
		<div class="hero-copy">
			<p class="role reveal">{content.hero.headline}</p>
			<h1 id="hero-title" class="reveal delay-1">{content.hero.eyebrow}</h1>
			<p class="tagline reveal delay-2">{content.hero.tagline}</p>
			<div class="cta-row reveal delay-3">
				<a class="btn btn-primary" href={`mailto:${siteConfig.email}`}>
					{content.hero.ctaContact}
				</a>
				<a class="btn btn-secondary" href={assetPath(siteConfig.resumePath[locale])} download>
					{content.hero.ctaResume}
				</a>
			</div>
		</div>
		<figure class="hero-brand reveal delay-2" aria-hidden="true">
			<img
				src={assetPath(siteConfig.brandLogo)}
				alt=""
				width="560"
				height="385"
				class="hero-logo"
			/>
		</figure>
	</div>
</section>

<style>
	.shell {
		width: min(100% - 2rem, var(--max-width));
		margin-inline: auto;
	}

	.hero {
		position: relative;
		padding: clamp(3rem, 8vw, 6.5rem) 0 clamp(3.5rem, 9vw, 7rem);
		overflow: clip;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 8% 0 auto auto;
		width: min(42vw, 28rem);
		height: min(42vw, 28rem);
		border-radius: 40% 60% 55% 45%;
		background: radial-gradient(circle at 30% 30%, rgba(232, 93, 42, 0.22), transparent 65%);
		filter: blur(8px);
		pointer-events: none;
	}

	.hero-grid {
		display: grid;
		gap: 2.5rem;
		align-items: center;
	}

	.role {
		margin: 0 0 0.65rem;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent-deep);
	}

	h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2.6rem, 7vw, 4.5rem);
		font-weight: var(--font-display-weight, 800);
		line-height: 1.02;
		letter-spacing: var(--font-tracking-display, -0.04em);
		color: var(--color-brand);
		max-width: 10ch;
	}

	.tagline {
		margin: 1.25rem 0 0;
		max-width: 34rem;
		font-size: clamp(1.05rem, 2vw, 1.25rem);
		color: var(--color-ink-soft);
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.3rem;
		border-radius: var(--radius);
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 0.2s var(--ease-out),
			background 0.2s var(--ease-out),
			box-shadow 0.2s var(--ease-out);
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-on-brand);
		box-shadow: 0 10px 24px var(--color-glow);
	}

	.btn-primary:hover {
		background: var(--color-accent-deep);
	}

	.btn-secondary {
		border: 1px solid var(--color-line);
		background: color-mix(in srgb, var(--color-surface-elevated) 75%, transparent);
		color: var(--color-brand);
	}

	.hero-brand {
		margin: 0;
		justify-self: center;
		width: min(100%, 26rem);
		aspect-ratio: 36 / 26;
		display: grid;
		place-items: center;
		padding: 1.25rem;
		border-radius: 1.25rem;
		background:
			radial-gradient(circle at 40% 35%, rgba(255, 255, 255, 0.75), transparent 55%),
			linear-gradient(145deg, rgba(74, 45, 117, 0.12), rgba(232, 93, 42, 0.1));
		box-shadow: var(--shadow-soft);
	}

	.hero-logo {
		width: 88%;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 12px 28px rgba(43, 24, 72, 0.18));
		animation: float-soft 7s ease-in-out infinite;
	}

	.reveal {
		animation: rise-in 0.7s var(--ease-out) both;
	}

	.delay-1 {
		animation-delay: 0.08s;
	}

	.delay-2 {
		animation-delay: 0.16s;
	}

	.delay-3 {
		animation-delay: 0.24s;
	}

	@keyframes float-soft {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-0.55rem);
		}
	}

	@media (min-width: 900px) {
		.hero-grid {
			grid-template-columns: 1.15fr 0.85fr;
			gap: 3rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-logo {
			animation: none;
		}
	}
</style>
