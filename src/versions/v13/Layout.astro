---
/** v13 · Folio — spreads de revista (composições ímpares/pares) */
import type { Locale } from '../../site.config';
import type { PortfolioContent } from '../../content/types';
import type { VersionId } from '../registry';
import { assetPath, localeHomePath, previewPath } from '../../lib/paths';
import { locales, siteConfig } from '../../site.config';
import '../../styles/tokens.css';
import '../../styles/typography.css';
import SiteHead from '../../components/SiteHead.astro';
import DevTools from '../../components/DevTools.astro';
import ContactLinks from '../../components/ContactLinks.astro';

type Props = { locale: Locale; content: PortfolioContent; versionId: VersionId; isPreview?: boolean };
const { locale, content, versionId, isPreview = false } = Astro.props;
const year = new Date().getFullYear();
const langHref = (l: Locale) => (isPreview ? previewPath(versionId, l) : localeHomePath(l));
---

<!doctype html>
<html lang={locale} translate="no" class="notranslate" data-fonts="outfit" data-palette="ocean" data-layout="v13">
	<head><SiteHead locale={locale} content={content} /></head>
	<body class="folio">
		{isPreview && <div class="preview-banner">Preview <strong>{versionId}</strong> · Folio <a href={localeHomePath(locale)}>Produção</a></div>}

		<section class="spread cover" id="topo">
			<div class="inner">
				<div class="cover-top">
					<div class="lang">{locales.map((l) => <a href={langHref(l)} aria-current={l === locale ? 'page' : undefined} hreflang={l}>{l.toUpperCase()}</a>)}</div>
					<ContactLinks content={content} variant="header" />
				</div>
				<p class="vol">Vol. 01 · {year}</p>
				<img src={assetPath(siteConfig.brandLogo)} alt="" width="80" height="44" />
				<h1>{content.hero.eyebrow}</h1>
				<p class="sub">{content.hero.headline}</p>
				<p class="tag">{content.hero.tagline}</p>
				<div class="cta">
					<a href={`mailto:${siteConfig.email}`}>{content.hero.ctaContact}</a>
					<a class="ghost" href={assetPath(siteConfig.resumePath)} download>{content.hero.ctaResume}</a>
				</div>
			</div>
		</section>

		<section class="spread about" id="sobre">
			<div class="inner two">
				<div class="left">
					<p class="pg">02</p>
					<h2>{content.about.title}</h2>
				</div>
				<div class="right">
					<p class="pull">{content.about.body}</p>
				</div>
			</div>
		</section>

		{content.experience.items.map((item, i) => (
			<section class:list={['spread', 'job', i % 2 === 1 && 'flip']} id={i === 0 ? 'experiencia' : undefined}>
				<div class="inner two">
					<div class="left">
						<p class="pg">{String(i + 3).padStart(2, '0')}</p>
						<p class="when">{item.period}</p>
						<h2>{item.role}</h2>
						<p class="co">{item.company}</p>
						<p class="loc">{item.location}</p>
					</div>
					<div class="right">
						<ul>{item.bullets.map((b) => <li>{b}</li>)}</ul>
						<p class="tech">{item.technologies.join(' · ')}</p>
					</div>
				</div>
			</section>
		))}

		<section class="spread skills" id="competencias">
			<div class="inner">
				<p class="pg">Skills</p>
				<h2>{content.skills.title}</h2>
				<div class="grid">
					{content.skills.groups.map((g) => (
						<div>
							<h3>{g.title}</h3>
							<p>{g.items.join(' · ')}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="spread colophon" id="fecho">
			<div class="inner">
				<p class="pg">Colophon</p>
				<p>{content.contact.body}</p>
				<ContactLinks content={content} variant="spread" />
				<p class="fine">© {year} {content.footer.rights}</p>
			</div>
		</section>

		<DevTools locale={locale} versionId={versionId} />
	</body>
</html>

<style>
	.preview-banner{display:flex;justify-content:space-between;padding:.45rem 1rem;background:var(--color-ink);color:var(--color-on-brand);font-size:.85rem}
	.preview-banner a{color:var(--color-preview-link);font-weight:700}
	.folio{margin:0;color:var(--color-ink);background:var(--color-canvas)}
	.spread{min-height:100vh;display:grid;align-items:center;padding:3rem 0;border-bottom:1px solid var(--color-line)}
	.inner{width:min(56rem,calc(100% - 2.5rem));margin-inline:auto}
	.inner.two{display:grid;gap:2rem}
	.cover{background:linear-gradient(165deg,var(--color-bg-top),var(--color-canvas))}
	.about{background:var(--color-bg-top)}
	.job{background:var(--color-surface-elevated)}
	.job.flip{background:var(--color-canvas)}
	.skills{background:linear-gradient(145deg,var(--color-brand-mid),var(--color-brand));color:var(--color-on-ink)}
	.colophon{background:linear-gradient(145deg,var(--color-accent),var(--color-accent-deep));color:var(--color-on-brand)}
	.cover-top{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:.65rem;margin-bottom:1.5rem}
	.lang{display:flex;gap:.4rem}
	.lang a{text-decoration:none;font-size:.72rem;font-weight:800;color:var(--color-muted)}
	.lang a[aria-current='page']{color:var(--color-brand)}
	.vol,.pg{margin:0;font-size:.75rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--color-accent-deep)}
	.skills .pg,.colophon .pg{color:color-mix(in srgb, var(--color-on-brand) 65%, transparent)}
	.cover img{width:4.5rem;height:auto;margin:1rem 0}
	h1{margin:.2rem 0 0;font-family:var(--font-display);font-size:clamp(2.8rem,8vw,5rem);font-weight:var(--font-display-weight);letter-spacing:var(--font-tracking-display);line-height:.95;color:var(--color-brand);max-width:9ch}
	.sub{margin:.8rem 0 0;font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--color-brand-mid)}
	.tag{margin:.6rem 0 0;max-width:32rem;color:var(--color-ink-soft)}
	.cta{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:1.5rem}
	.cta a{text-decoration:none;font-weight:700;padding:.7rem 1.05rem;border-radius:.35rem;background:var(--color-accent);color:var(--color-on-brand)}
	.cta a.ghost{background:transparent;border:1px solid var(--color-line);color:var(--color-brand)}
	h2{margin:.4rem 0 0;font-family:var(--font-display);font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.05}
	.skills h2{color:var(--color-on-brand)}
	.pull{margin:0;font-size:1.2rem;line-height:1.55;color:var(--color-ink-soft)}
	.when{margin:.75rem 0 0;font-weight:700;color:var(--color-muted);font-size:.9rem}
	.co{margin:.35rem 0 0;font-weight:700;color:var(--color-brand-mid)}
	.loc{margin:.2rem 0 0;font-size:.88rem;color:var(--color-muted)}
	.job ul{margin:0;padding-left:1.1rem;color:var(--color-ink-soft)}
	.tech{margin:.75rem 0 0;font-size:.82rem;font-weight:600;color:var(--color-muted)}
	.grid{display:grid;gap:1.25rem;margin-top:1.5rem}
	.grid h3{margin:0 0 .35rem;font-family:var(--font-display);font-size:1.05rem;color:var(--color-on-brand)}
	.grid p{margin:0;opacity:.9}
	.mail{display:inline-flex;margin:1rem 0;padding:.75rem 1.1rem;border-radius:.35rem;background:var(--color-surface-elevated);color:var(--color-accent-deep);font-weight:800;text-decoration:none}
	.colophon a{color:var(--color-on-brand);font-weight:700}
	.fine{opacity:.85;font-size:.9rem}
	@media (min-width:860px){
		.inner.two{grid-template-columns:1fr 1.15fr;align-items:start;gap:3rem}
		.job.flip .left{order:2}
		.job.flip .right{order:1}
		.grid{grid-template-columns:1fr 1fr}
	}
</style>
