---
/** v10 · Twin — seções 50/50 tela cheia, lados alternando */
import type { Locale } from '../../site.config';
import type { PortfolioContent } from '../../content/types';
import type { VersionId } from '../registry';
import { assetPath, localeHomePath, previewPath } from '../../lib/paths';
import { locales, siteConfig } from '../../site.config';
import '../../styles/tokens.css';
import '../../styles/typography.css';
import SiteHead from '../../components/SiteHead.astro';
import DevTools from '../../components/DevTools.astro';
import ContactLinks from '../../components/ContactLinks.astro';
import CompanyLink from '../../components/CompanyLink.astro';

type Props = { locale: Locale; content: PortfolioContent; versionId: VersionId; isPreview?: boolean };
const { locale, content, versionId, isPreview = false } = Astro.props;
const year = new Date().getFullYear();
const langHref = (l: Locale) => (isPreview ? previewPath(versionId, l) : localeHomePath(l));
---

<!doctype html>
<html lang={locale} translate="no" class="notranslate" data-fonts="outfit" data-palette="ocean" data-layout="v10">
	<head><SiteHead locale={locale} content={content} /></head>
	<body class="twin">
		{isPreview && <div class="preview-banner">Preview <strong>{versionId}</strong> · Twin <a href={localeHomePath(locale)}>Produção</a></div>}
		<header class="float">
			<a class="brand" href="#topo"><img src={assetPath(siteConfig.brandLogo)} alt="" width="40" height="22" /></a>
			<div class="header-actions">
				<ContactLinks content={content} locale={locale} variant="header" />
				<div class="lang">{locales.map((l) => <a href={langHref(l)} aria-current={l === locale ? 'page' : undefined} hreflang={l}>{l.toUpperCase()}</a>)}</div>
			</div>
		</header>

		<section class="split" id="topo">
			<div class="pane text">
				<p class="role">{content.hero.headline}</p>
				<h1>{content.hero.eyebrow}</h1>
				<p class="tag">{content.hero.tagline}</p>
				<div class="cta">
					<a href={`mailto:${siteConfig.email}`}>{content.hero.ctaContact}</a>
					<a class="ghost" href={assetPath(siteConfig.resumePath[locale])} download>{content.hero.ctaResume}</a>
				</div>
			</div>
			<div class="pane visual brand-pane" aria-hidden="true">
				<img src={assetPath(siteConfig.brandLogo)} alt="" />
			</div>
		</section>

		<section class="split flip" id="sobre">
			<div class="pane visual aubergine" aria-hidden="true"><span>{content.about.title}</span></div>
			<div class="pane text"><h2>{content.about.title}</h2><p>{content.about.body}</p></div>
		</section>

		<section class="split stack-exp" id="experiencia">
			<div class="pane text wide">
				<h2>{content.experience.title}</h2>
				{content.experience.items.map((item) => (
					<article class="job">
						<p class="when">{item.period}</p>
						<h3>{item.role} · <CompanyLink name={item.company} url={item.companyUrl} /></h3>
						<p class="job-summary">{item.summary}</p>
					</article>
				))}
			</div>
			<div class="pane visual cream" aria-hidden="true"><span>2015—</span></div>
		</section>

		<section class="split flip" id="competencias">
			<div class="pane visual orange" aria-hidden="true"><span>{content.skills.title}</span></div>
			<div class="pane text">
				<h2>{content.skills.title}</h2>
				{content.skills.groups.map((g) => <p><strong>{g.title}</strong><br />{g.items.join(' · ')}</p>)}
			</div>
		</section>

		<section class="split" id="fecho">
			<div class="pane text">
				<p>{content.contact.body}</p>
				<ContactLinks content={content} locale={locale} variant="rail" />
				<p class="fine">© {year} {content.footer.rights}</p>
			</div>
			<div class="pane visual ink" aria-hidden="true"><span>@</span></div>
		</section>

		<DevTools locale={locale} versionId={versionId} />
	</body>
</html>

<style>
	.preview-banner{display:flex;justify-content:space-between;padding:.45rem 1rem;background:var(--color-ink);color:var(--color-on-brand);font-size:.85rem;position:relative;z-index:40}
	.preview-banner a{color:var(--color-preview-link);font-weight:700}
	.twin{margin:0;color:var(--color-ink)}
	.float{position:fixed;top:1rem;left:0;right:0;z-index:30;display:flex;justify-content:space-between;padding:0 1.25rem;pointer-events:none}
	.float a,.float :global(nav){pointer-events:auto}
	.header-actions{display:flex;align-items:center;gap:.5rem;pointer-events:none}
	.header-actions :global(*){pointer-events:auto}
	.brand img{width:2.4rem;height:auto;filter:drop-shadow(0 2px 8px rgba(0,0,0,.15))}
	.lang a{margin-left:.35rem;text-decoration:none;font-size:.72rem;font-weight:800;padding:.3rem .45rem;background:color-mix(in srgb, var(--color-surface-elevated) 90%, transparent);border-radius:.25rem;color:var(--color-muted)}
	.lang a[aria-current='page']{color:var(--color-brand)}
	.split{display:grid;min-height:100vh}
	.pane{display:grid;align-content:center;padding:4rem 8vw}
	.pane.text{background:var(--color-bg-top)}
	.pane.visual{place-items:center;font-family:var(--font-display);font-weight:800;font-size:clamp(2rem,6vw,4rem);letter-spacing:-.03em;color:rgba(255,255,255,.35)}
	.brand-pane{background:linear-gradient(145deg,var(--color-brand-mid),var(--color-brand))}
	.brand-pane img{width:min(40%,12rem);height:auto;opacity:.95}
	.aubergine{background:linear-gradient(160deg,var(--color-ink),var(--color-brand-mid))}
	.cream{background:linear-gradient(160deg,var(--color-canvas),var(--color-canvas));color:color-mix(in srgb, var(--color-ink) 20%, transparent)}
	.orange{background:linear-gradient(145deg,var(--color-accent),var(--color-accent-deep))}
	.ink{background:var(--color-ink)}
	.role{margin:0;font-size:.78rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--color-accent-deep)}
	h1{margin:.4rem 0 0;font-family:var(--font-display);font-size:clamp(2.4rem,5vw,4rem);font-weight:var(--font-display-weight);letter-spacing:var(--font-tracking-display);line-height:1;color:var(--color-brand);max-width:10ch}
	.tag{margin:1rem 0 0;color:var(--color-ink-soft);max-width:28rem}
	.cta{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:1.4rem}
	.cta a{text-decoration:none;font-weight:700;padding:.7rem 1rem;border-radius:.35rem;background:var(--color-accent);color:var(--color-on-brand)}
	.cta a.ghost{background:transparent;border:1px solid var(--color-line);color:var(--color-brand)}
	h2{margin:0 0 1rem;font-family:var(--font-display);font-size:clamp(1.6rem,3vw,2.2rem);color:var(--color-brand)}
	.job+.job{margin-top:1.25rem}
	.when{margin:0;font-size:.82rem;font-weight:700;color:var(--color-muted)}
	.job h3{margin:.2rem 0 .4rem;font-family:var(--font-display);font-size:1.1rem}
	.job-summary{margin:0;color:var(--color-ink-soft);font-size:.95rem}
	.mail{display:inline-flex;margin:.5rem 0 1rem;padding:.7rem 1rem;border-radius:.35rem;background:var(--color-brand);color:var(--color-on-brand);font-weight:800;text-decoration:none}
	.fine{color:var(--color-muted);font-size:.9rem}
	@media (min-width:860px){
		.split{grid-template-columns:1fr 1fr}
		.split.flip .pane.text{order:2}
		.split.flip .pane.visual{order:1}
		.pane.wide{padding-block:3rem}
	}
	@media (max-width:859px){
		.split{min-height:auto}
		.pane.visual{min-height:40vh;padding:3rem}
		.pane.text{padding:3rem 1.5rem}
	}
</style>
