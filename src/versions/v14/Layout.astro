---
/** v14 · Ingress — carta/longo lead; depois seções estruturadas */
import type { Locale } from '../../site.config';
import type { PortfolioContent } from '../../content/types';
import type { VersionId } from '../registry';
import { assetPath, localeHomePath, previewPath } from '../../lib/paths';
import { locales, siteConfig } from '../../site.config';
import '../../styles/tokens.css';
import '../../styles/typography.css';
import SiteHead from '../../components/SiteHead.astro';
import DevTools from '../../components/DevTools.astro';
import ContactLinks from '../../components/ContactLinks.astro';

type Props = { locale: Locale; content: PortfolioContent; versionId: VersionId; isPreview?: boolean };
const { locale, content, versionId, isPreview = false } = Astro.props;
const year = new Date().getFullYear();
const langHref = (l: Locale) => (isPreview ? previewPath(versionId, l) : localeHomePath(l));
const greeting =
	locale === 'en' ? 'Hello,' : locale === 'es' ? 'Hola,' : 'Olá,';
const signoff =
	locale === 'en' ? 'Best,' : locale === 'es' ? 'Un saludo,' : 'Um abraço,';
---

<!doctype html>
<html lang={locale} translate="no" class="notranslate" data-fonts="outfit" data-palette="ocean" data-layout="v14">
	<head><SiteHead locale={locale} content={content} /></head>
	<body class="ingress">
		{isPreview && <div class="preview-banner">Preview <strong>{versionId}</strong> · Ingress <a href={localeHomePath(locale)}>Produção</a></div>}
		<header class="top shell">
			<a class="brand" href="#topo"><img src={assetPath(siteConfig.brandLogo)} alt="" width="44" height="24" />{siteConfig.name}</a>
			<div class="header-actions">
				<ContactLinks content={content} locale={locale} variant="header" />
				<div class="lang">{locales.map((l) => <a href={langHref(l)} aria-current={l === locale ? 'page' : undefined} hreflang={l}>{l.toUpperCase()}</a>)}</div>
			</div>
		</header>

		<main class="shell" id="topo">
			<article class="letter">
				<p class="greet">{greeting}</p>
				<p class="lead">
					<strong>{content.hero.eyebrow}</strong> — {content.hero.headline}. {content.hero.tagline}
				</p>
				<p class="body" id="sobre">{content.about.body}</p>
				<p class="sign">{signoff}<br /><span>{siteConfig.name}</span></p>
				<p class="cta">
					<a href={`mailto:${siteConfig.email}`}>{content.hero.ctaContact}</a>
					·
					<a href={assetPath(siteConfig.resumePath[locale])} download>{content.hero.ctaResume}</a>
				</p>
			</article>

			<nav class="jump" aria-label="Primary">
				<a href="#experiencia">{content.nav.experience}</a>
				<a href="#competencias">{content.nav.skills}</a>
			</nav>

			<section id="experiencia" class="struct">
				<h2>{content.experience.title}</h2>
				{content.experience.items.map((item) => (
					<article class="job">
						<div class="meta">
							<p class="when">{item.period}</p>
							<p class="loc">{item.location}</p>
						</div>
						<div>
							<h3>{item.role}</h3>
							<p class="co">{item.company}</p>
							<p class="job-summary">{item.summary}</p>
							<p class="tech">{item.technologies.join(' · ')}</p>
						</div>
					</article>
				))}
			</section>

			<section id="competencias" class="struct">
				<h2>{content.skills.title}</h2>
				<div class="skills">{content.skills.groups.map((g) => <div><h3>{g.title}</h3><p>{g.items.join(' · ')}</p></div>)}</div>
			</section>

			<footer>© {year} {content.footer.rights}</footer>
		</main>
		<DevTools locale={locale} versionId={versionId} />
	</body>
</html>

<style>
	.preview-banner{display:flex;justify-content:space-between;padding:.45rem 1rem;background:var(--color-brand);color:var(--color-on-brand);font-size:.85rem}
	.preview-banner a{color:var(--color-preview-link);font-weight:700}
	.ingress{margin:0;color:var(--color-ink);background:radial-gradient(800px 400px at 20% 0%,rgba(233,84,32,.12),transparent 55%),var(--color-canvas)}
	.shell{width:min(40rem,calc(100% - 2rem));margin-inline:auto}
	.top{display:flex;justify-content:space-between;align-items:center;padding:1rem 0}
	.header-actions{display:flex;align-items:center;gap:.65rem}
	.brand{display:inline-flex;gap:.5rem;align-items:center;text-decoration:none;font-family:var(--font-display);font-weight:700;color:var(--color-brand);font-size:.95rem}
	.brand img{width:2.3rem;height:auto}
	.lang a{margin-left:.4rem;text-decoration:none;font-size:.72rem;font-weight:800;color:var(--color-muted)}
	.lang a[aria-current='page']{color:var(--color-brand)}
	.letter{padding:2rem 0 1.5rem}
	.greet{margin:0;font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--color-brand-mid)}
	.lead{margin:1.25rem 0 0;font-size:clamp(1.35rem,3.5vw,1.75rem);line-height:1.45;font-family:var(--font-display);letter-spacing:-.02em;color:var(--color-ink)}
	.body{margin:1.5rem 0 0;font-size:1.12rem;line-height:1.75;color:var(--color-ink-soft)}
	.sign{margin:2rem 0 0;font-size:1.05rem;line-height:1.6}
	.sign span{font-family:var(--font-display);font-weight:700;color:var(--color-brand)}
	.cta{margin:1.5rem 0 0}
	.cta a{font-weight:700;color:var(--color-accent-deep)}
	.jump{display:flex;flex-wrap:wrap;gap:.75rem 1.25rem;padding:1rem 0;border-top:1px solid var(--color-line);border-bottom:1px solid var(--color-line);margin-bottom:.5rem}
	.jump a{text-decoration:none;font-family:var(--font-display);font-size:.8rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--color-brand)}
	.struct{padding:2.25rem 0;border-bottom:1px solid var(--color-line)}
	h2{margin:0 0 1.25rem;font-family:var(--font-display);font-size:1.35rem;color:var(--color-brand)}
	.job{display:grid;gap:.75rem;padding:1.15rem 0}
	.job+.job{border-top:1px dashed var(--color-line)}
	.when{margin:0;font-size:.82rem;font-weight:700;color:var(--color-muted)}
	.loc{margin:.15rem 0 0;font-size:.8rem;color:var(--color-muted)}
	.job h3{margin:0;font-family:var(--font-display);font-size:1.15rem}
	.co{margin:.2rem 0 .5rem;font-weight:700;color:var(--color-brand-mid)}
	.job-summary{margin:0;color:var(--color-ink-soft)}
	.tech{margin:.5rem 0 0;font-size:.8rem;font-weight:600;color:var(--color-muted)}
	.skills{display:grid;gap:1rem}
	.skills h3{margin:0 0 .25rem;font-family:var(--font-display);font-size:1rem}
	.skills p{margin:0;color:var(--color-ink-soft)}
	footer{padding:1.5rem 0 7rem;color:var(--color-muted);font-size:.88rem}
	@media (min-width:700px){
		.job{grid-template-columns:8rem 1fr;gap:1.5rem}
		.skills{grid-template-columns:1fr 1fr}
	}
</style>
