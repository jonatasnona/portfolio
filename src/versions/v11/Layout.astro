---
/** v11 · Mosaic — blocos de altura variável (masonry) */
import type { Locale } from '../../site.config';
import type { PortfolioContent } from '../../content/types';
import type { VersionId } from '../registry';
import { assetPath, localeHomePath, previewPath } from '../../lib/paths';
import { locales, siteConfig } from '../../site.config';
import '../../styles/tokens.css';
import '../../styles/typography.css';
import SiteHead from '../../components/SiteHead.astro';
import DevTools from '../../components/DevTools.astro';
import ContactLinks from '../../components/ContactLinks.astro';

type Props = { locale: Locale; content: PortfolioContent; versionId: VersionId; isPreview?: boolean };
const { locale, content, versionId, isPreview = false } = Astro.props;
const year = new Date().getFullYear();
const langHref = (l: Locale) => (isPreview ? previewPath(versionId, l) : localeHomePath(l));
---

<!doctype html>
<html lang={locale} translate="no" class="notranslate" data-fonts="outfit" data-palette="ocean" data-layout="v11">
	<head><SiteHead locale={locale} content={content} /></head>
	<body class="mosaic">
		{isPreview && <div class="preview-banner">Preview <strong>{versionId}</strong> · Mosaic <a href={localeHomePath(locale)}>Produção</a></div>}
		<header class="top shell">
			<a class="brand" href="#topo"><img src={assetPath(siteConfig.brandLogo)} alt="" width="48" height="26" />{siteConfig.name}</a>
			<nav class="nav">
				<a href="#experiencia">{content.nav.experience}</a>
				<a href="#competencias">{content.nav.skills}</a>
			</nav>
			<div class="header-actions">
				<ContactLinks content={content} locale={locale} variant="header" />
				<div class="lang">{locales.map((l) => <a href={langHref(l)} aria-current={l === locale ? 'page' : undefined} hreflang={l}>{l.toUpperCase()}</a>)}</div>
			</div>
		</header>

		<main class="shell" id="topo">
			<section class="hero tile tall">
				<p class="role">{content.hero.headline}</p>
				<h1>{content.hero.eyebrow}</h1>
				<p class="tag">{content.hero.tagline}</p>
				<p class="cta"><a href={`mailto:${siteConfig.email}`}>{content.hero.ctaContact}</a> · <a href={assetPath(siteConfig.resumePath[locale])} download>{content.hero.ctaResume}</a></p>
			</section>

			<section id="sobre" class="tile about">
				<h2>{content.about.title}</h2>
				<p>{content.about.body}</p>
			</section>

			<div class="wall" id="experiencia">
				{content.experience.items.map((item, i) => (
					<article class:list={['tile', 'job', i % 3 === 0 && 'span', i % 2 === 1 && 'tint']}>
						<p class="when">{item.period}</p>
						<h3>{item.role}</h3>
						<p class="co">{item.company} · {item.location}</p>
						<ul>{item.bullets.map((b) => <li>{b}</li>)}</ul>
						<p class="tech">{item.technologies.join(' · ')}</p>
					</article>
				))}
			</div>

			<section id="competencias" class="skills-wall">
				<h2 class="sec">{content.skills.title}</h2>
				<div class="wall tight">
					{content.skills.groups.map((g, i) => (
						<div class:list={['tile', 'skill', i === 0 && 'accent']}>
							<h3>{g.title}</h3>
							<p>{g.items.join(' · ')}</p>
						</div>
					))}
				</div>
			</section>

			<footer>© {year} {content.footer.rights}</footer>
		</main>
		<DevTools locale={locale} versionId={versionId} />
	</body>
</html>

<style>
	.preview-banner{display:flex;justify-content:space-between;padding:.45rem 1rem;background:var(--color-brand);color:var(--color-on-brand);font-size:.85rem}
	.preview-banner a{color:var(--color-preview-link);font-weight:700}
	.mosaic{margin:0;color:var(--color-ink);background:var(--color-canvas)}
	.shell{width:min(64rem,calc(100% - 1.5rem));margin-inline:auto}
	.top{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:.75rem;padding:1rem 0}
	.brand{display:inline-flex;gap:.5rem;align-items:center;text-decoration:none;font-family:var(--font-display);font-weight:700;color:var(--color-brand)}
	.brand img{width:2.5rem;height:auto}
	.nav{display:none;gap:1rem}
	.nav a{text-decoration:none;font-size:.85rem;font-weight:700;color:var(--color-ink-soft)}
	.header-actions{display:flex;align-items:center;gap:.5rem}
	.lang a{margin-left:.35rem;text-decoration:none;font-size:.72rem;font-weight:800;color:var(--color-muted)}
	.lang a[aria-current='page']{color:var(--color-brand)}
	.tile{background:var(--color-surface-elevated);border:1px solid var(--color-line);border-radius:.75rem;padding:1.35rem 1.4rem;margin-bottom:1rem;break-inside:avoid}
	.hero{margin-top:.5rem}
	.hero.tall{padding:2rem 1.6rem}
	.role{margin:0;font-size:.78rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--color-accent-deep)}
	h1{margin:.35rem 0 0;font-family:var(--font-display);font-size:clamp(2.2rem,5vw,3.4rem);font-weight:var(--font-display-weight);letter-spacing:var(--font-tracking-display);color:var(--color-brand);line-height:1.05}
	.tag{margin:.8rem 0 0;color:var(--color-ink-soft);max-width:36rem}
	.cta a{font-weight:700;color:var(--color-brand)}
	.about h2,.sec,h2{margin:0 0 .75rem;font-family:var(--font-display);color:var(--color-brand)}
	.wall{column-count:1;column-gap:1rem}
	.wall .tile{display:inline-block;width:100%}
	.job.tint{background:var(--color-canvas)}
	.job.span{background:linear-gradient(160deg,var(--color-surface-elevated),var(--color-canvas))}
	.when{margin:0;font-size:.8rem;font-weight:700;color:var(--color-muted)}
	.job h3{margin:.3rem 0 0;font-family:var(--font-display);font-size:1.2rem}
	.co{margin:.2rem 0 .55rem;font-weight:700;color:var(--color-brand-mid);font-size:.92rem}
	.job ul{margin:0;padding-left:1.05rem;color:var(--color-ink-soft);font-size:.95rem}
	.tech{margin:.55rem 0 0;font-size:.78rem;font-weight:600;color:var(--color-muted)}
	.skills-wall{margin:1.5rem 0}
	.skill h3{margin:0 0 .35rem;font-family:var(--font-display)}
	.skill p{margin:0;color:var(--color-ink-soft)}
	.skill.accent{background:var(--color-ink);color:var(--color-on-ink);border-color:transparent}
	.skill.accent h3{color:var(--color-on-brand)}
	.skill.accent p{color:color-mix(in srgb, var(--color-surface-elevated) 85%, transparent)}
	footer{padding:1rem 0 7rem;color:var(--color-muted);font-size:.88rem}
	@media (min-width:640px){.wall{column-count:2}.nav{display:flex}}
	@media (min-width:980px){.wall{column-count:3}.wall.tight{column-count:2}}
</style>
