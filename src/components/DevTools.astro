---
/**
 * DEV panel: typography + palette + layout (live).
 * Layouts navigate to /v/<id>/ — typography and palette switch via CSS.
 * Only rendered when import.meta.env.DEV is true.
 */
import type { Locale } from '../site.config';
import type { VersionId } from '../versions/registry';
import { versionIds, versionMeta } from '../versions/registry';
import { siteConfig } from '../site.config';

type Props = {
	locale: Locale;
	versionId: VersionId;
};

const isDev = import.meta.env.DEV;
const { locale, versionId } = Astro.props;
const base = siteConfig.base.replace(/\/$/, '') || '';

const palettes = [
	{ id: 'ocean', label: 'Ocean', title: 'Navy + coral (default)' },
	{ id: 'mandril', label: 'Mandril', title: 'Ubuntu / Mandril' },
	{ id: 'slate', label: 'Slate', title: 'Steel + teal' },
	{ id: 'forest', label: 'Forest', title: 'Green + amber' },
	{ id: 'noir', label: 'Noir', title: 'Charcoal + blue' },
	{ id: 'clay', label: 'Clay', title: 'Stone + indigo' },
] as const;
---

{
	isDev && (
		<div
			id="dev-tools-panel"
			class="dev-tools"
			data-dev-tools
			data-base={base}
			data-locale={locale}
			data-version={versionId}
		>
			<div class="dev-tools__header">
				<p class="dev-tools__title">Preview tools</p>
				<button
					type="button"
					class="dev-tools__close"
					data-dev-tools-close
					aria-label="Fechar ferramentas de preview"
					title="Fechar"
					hidden
				>
					<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
						<path d="M6 6l12 12M18 6 6 18" />
					</svg>
				</button>
			</div>

			<div class="dev-tools__block" data-dev-fonts>
				<p class="dev-tools__label">Tipografia</p>
				<div class="dev-tools__row" role="group" aria-label="Tipografia">
					<button type="button" data-fonts="outfit" title="Outfit + Literata">
						Outfit
					</button>
					<button type="button" data-fonts="space" title="Space Grotesk + Source Serif 4">
						Space
					</button>
					<button type="button" data-fonts="bricolage" title="Bricolage + Figtree">
						Bricolage
					</button>
				</div>
			</div>

			<div class="dev-tools__block" data-dev-palettes>
				<p class="dev-tools__label">Paleta</p>
				<div class="dev-tools__row" role="group" aria-label="Paletas">
					{
						palettes.map((p) => (
							<button type="button" data-palette={p.id} title={p.title}>
								{p.label}
							</button>
						))
					}
				</div>
			</div>

			<div class="dev-tools__block" data-dev-layouts>
				<p class="dev-tools__label">Layout</p>
				<div class="dev-tools__row" role="group" aria-label="Layouts">
					{
						versionIds.map((id) => (
							<button
								type="button"
								data-layout={id}
								title={`${versionMeta[id].title}: ${versionMeta[id].blurb}`}
								aria-pressed={id === versionId ? 'true' : 'false'}
							>
								{versionMeta[id].label} · {versionMeta[id].title}
							</button>
						))
					}
				</div>
			</div>
		</div>
	)
}

{
	isDev && (
		<script is:inline>
			(() => {
				const tools = document.querySelector('[data-dev-tools]');
				if (!tools) return;

				const FONT_KEY = 'portfolio:dev-fonts';
				const PALETTE_KEY = 'portfolio:dev-palette';
				const LAYOUT_KEY = 'portfolio:dev-layout';
				const FONTS = new Set(['outfit', 'space', 'bricolage']);
				const PALETTES = new Set(['mandril', 'slate', 'forest', 'noir', 'clay', 'ocean']);
				const FONT_DEFAULT = 'outfit';
				const PALETTE_DEFAULT = 'ocean';
				const root = document.documentElement;
				const fontPanel = tools.querySelector('[data-dev-fonts]');
				const palettePanel = tools.querySelector('[data-dev-palettes]');
				const layoutPanel = tools.querySelector('[data-dev-layouts]');
				const closeButton = tools.querySelector('[data-dev-tools-close]');
				const previewBar = document.querySelector('.preview-banner');
				const base = tools.getAttribute('data-base') || '';
				const locale = tools.getAttribute('data-locale') || 'pt';
				let trigger = null;

				const setToolsOpen = (open) => {
					tools.hidden = !open;
					trigger?.setAttribute('aria-expanded', open ? 'true' : 'false');
				};

				if (previewBar && closeButton) {
					trigger = document.createElement('button');
					trigger.type = 'button';
					trigger.className = 'dev-tools-trigger';
					trigger.setAttribute('aria-label', 'Abrir ferramentas de preview');
					trigger.setAttribute('title', 'Ferramentas de preview');
					trigger.setAttribute('aria-controls', 'dev-tools-panel');
					trigger.setAttribute('aria-expanded', 'true');
					trigger.innerHTML =
						'<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16"><path d="M4 7h10M18 7h2M4 17h2M10 17h10M14 4v6M10 14v6"/></svg>';
					previewBar.append(trigger);
					closeButton.hidden = false;

					closeButton.addEventListener('click', () => {
						setToolsOpen(false);
						trigger.focus();
					});

					trigger.addEventListener('click', () => {
						setToolsOpen(true);
					});
				}

				const applyFont = (id) => {
					if (!FONTS.has(id)) id = FONT_DEFAULT;
					root.setAttribute('data-fonts', id);
					try {
						localStorage.setItem(FONT_KEY, id);
					} catch {}
					fontPanel?.querySelectorAll('button[data-fonts]').forEach((btn) => {
						btn.setAttribute(
							'aria-pressed',
							btn.getAttribute('data-fonts') === id ? 'true' : 'false',
						);
					});
				};

				const applyPalette = (id) => {
					if (!PALETTES.has(id)) id = PALETTE_DEFAULT;
					root.setAttribute('data-palette', id);
					try {
						localStorage.setItem(PALETTE_KEY, id);
					} catch {}
					palettePanel?.querySelectorAll('button[data-palette]').forEach((btn) => {
						btn.setAttribute(
							'aria-pressed',
							btn.getAttribute('data-palette') === id ? 'true' : 'false',
						);
					});
				};

				let fontInitial = FONT_DEFAULT;
				let paletteInitial = PALETTE_DEFAULT;
				try {
					const savedFont = localStorage.getItem(FONT_KEY);
					if (savedFont && FONTS.has(savedFont)) fontInitial = savedFont;
					const savedPalette = localStorage.getItem(PALETTE_KEY);
					if (savedPalette && PALETTES.has(savedPalette)) paletteInitial = savedPalette;
				} catch {}
				applyFont(fontInitial);
				applyPalette(paletteInitial);

				fontPanel?.addEventListener('click', (event) => {
					const btn = event.target.closest('button[data-fonts]');
					if (!btn) return;
					applyFont(btn.getAttribute('data-fonts'));
				});

				palettePanel?.addEventListener('click', (event) => {
					const btn = event.target.closest('button[data-palette]');
					if (!btn) return;
					applyPalette(btn.getAttribute('data-palette'));
				});

				const layoutUrl = (id) => {
					if (locale === 'pt') return `${base}/v/${id}/`;
					return `${base}/v/${id}/${locale}/`;
				};

				layoutPanel?.addEventListener('click', (event) => {
					const btn = event.target.closest('button[data-layout]');
					if (!btn) return;
					const id = btn.getAttribute('data-layout');
					if (!id) return;
					try {
						localStorage.setItem(LAYOUT_KEY, id);
					} catch {}
					const next = layoutUrl(id);
					if (location.pathname.replace(/\/$/, '') === next.replace(/\/$/, '')) return;
					location.assign(next);
				});
			})();
		</script>
	)
}

<style>
	.dev-tools {
		position: fixed;
		right: 1rem;
		bottom: 1rem;
		z-index: 100;
		display: grid;
		gap: 0.75rem;
		width: min(24rem, calc(100vw - 2rem));
		max-height: min(70vh, 36rem);
		overflow: auto;
		padding: 0.75rem 0.85rem;
		border: 1px solid var(--color-line);
		border-radius: 0.55rem;
		background: color-mix(in srgb, var(--color-surface-elevated) 96%, transparent);
		box-shadow: var(--shadow-soft);
		backdrop-filter: blur(10px);
		font-family: var(--font-body);
	}

	.dev-tools[hidden],
	.dev-tools__close[hidden] {
		display: none;
	}

	.dev-tools__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.dev-tools__title {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-ink-soft);
	}

	.dev-tools__close {
		appearance: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 1px solid var(--color-line);
		border-radius: 0.3rem;
		background: var(--color-surface-elevated);
		color: var(--color-ink-soft);
		cursor: pointer;
	}

	.dev-tools__close svg {
		display: block;
		fill: none;
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
	}

	.dev-tools__close:hover {
		border-color: var(--color-accent);
		color: var(--color-brand);
	}

	.dev-tools__close:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.dev-tools__block {
		display: grid;
		gap: 0.4rem;
	}

	.dev-tools__label {
		margin: 0;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.dev-tools__row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.dev-tools__row button {
		appearance: none;
		border: 1px solid var(--color-line);
		border-radius: 0.3rem;
		background: var(--color-surface-elevated);
		color: var(--color-ink-soft);
		font: inherit;
		font-size: 0.72rem;
		font-weight: 700;
		padding: 0.38rem 0.5rem;
		cursor: pointer;
		transition:
			background 0.15s var(--ease-out),
			color 0.15s var(--ease-out),
			border-color 0.15s var(--ease-out);
	}

	.dev-tools__row button:hover {
		border-color: var(--color-accent);
		color: var(--color-brand);
	}

	.dev-tools__row button[aria-pressed='true'] {
		background: var(--color-brand);
		border-color: var(--color-brand);
		color: var(--color-on-brand);
	}

	:global(.preview-banner:has(.dev-tools-trigger)) {
		align-items: center;
		gap: 0.6rem;
	}

	:global(.dev-tools-trigger) {
		appearance: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 2rem;
		height: 2rem;
		margin-left: 0.25rem;
		padding: 0;
		border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
		border-radius: 0.3rem;
		background: color-mix(in srgb, currentColor 10%, transparent);
		color: inherit;
		cursor: pointer;
	}

	:global(.dev-tools-trigger:hover) {
		background: color-mix(in srgb, currentColor 18%, transparent);
	}

	:global(.dev-tools-trigger svg) {
		display: block;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	:global(.dev-tools-trigger:focus-visible) {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}
</style>
