---
/**
 * Links de contato por ícone.
 * Variantes: header | row | stack | rail | spread | mono | inline
 *
 * header — chrome persistente (recomendação UX: ação sempre visível)
 * demais — fecho leve em layouts painel (Poster / Twin / Folio)
 */
import type { PortfolioContent } from '../content/types';
import { assetPath } from '../lib/paths';
import { siteConfig } from '../site.config';

export type ContactLinksVariant =
	| 'header'
	| 'row'
	| 'stack'
	| 'rail'
	| 'spread'
	| 'mono'
	| 'inline';

type Props = {
	content: PortfolioContent;
	variant?: ContactLinksVariant;
	class?: string;
};

const { content, variant = 'row', class: className } = Astro.props;
const labels = content.contact.labels;
const resumeLabel = content.nav.resume;

const links = [
	{
		id: 'email',
		href: `mailto:${siteConfig.email}`,
		label: labels.email,
		external: false,
		download: false,
	},
	{
		id: 'linkedin',
		href: siteConfig.linkedin,
		label: labels.linkedin,
		external: true,
		download: false,
	},
	{
		id: 'github',
		href: siteConfig.github,
		label: labels.github,
		external: true,
		download: false,
	},
	{
		id: 'resume',
		href: assetPath(siteConfig.resumePath),
		label: resumeLabel,
		external: false,
		download: true,
	},
] as const;
---

<nav
	class:list={['contact-links', `contact-links--${variant}`, className]}
	aria-label={content.nav.contact}
>
	{
		links.map((link) => (
			<a
				class:list={['contact-links__item', `contact-links__item--${link.id}`]}
				href={link.href}
				aria-label={link.label}
				title={link.label}
				target={link.external ? '_blank' : undefined}
				rel={link.external ? 'noopener noreferrer' : undefined}
				download={link.download || undefined}
			>
				<span class="contact-links__icon" aria-hidden="true">
					{link.id === 'email' && (
						<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="5" width="18" height="14" rx="2" />
							<path d="m3 7 9 7 9-7" />
						</svg>
					)}
					{link.id === 'linkedin' && (
						<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
							<path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V23h-4V8.5zM8.5 8.5h3.8v2h.05c.53-1 1.82-2.05 3.75-2.05 4.01 0 4.75 2.64 4.75 6.07V23h-4v-5.9c0-1.41-.03-3.22-1.96-3.22-1.96 0-2.26 1.53-2.26 3.11V23h-4V8.5z" />
						</svg>
					)}
					{link.id === 'github' && (
						<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.28-.01-1.02-.02-2.01-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.08 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.4s2.04.13 3 .4c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.91-.01 3.31 0 .32.22.7.82.58C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z" />
						</svg>
					)}
					{link.id === 'resume' && (
						<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
							<path d="M14 3v5h5" />
							<path d="M12 18v-6" />
							<path d="m9 15 3 3 3-3" />
						</svg>
					)}
				</span>
				{ (variant === 'mono' || variant === 'stack') && (
					<span class="contact-links__text">{link.label}</span>
				)}
			</a>
		))
	}
</nav>

<style>
	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin: 1rem 0 0;
	}

	.contact-links--header {
		flex-wrap: nowrap;
		gap: 0.35rem;
		margin: 0;
	}

	.contact-links--header .contact-links__item {
		min-width: 2.35rem;
		min-height: 2.35rem;
		padding: 0.4rem;
		border-radius: 0.35rem;
		border-color: var(--color-line);
		color: var(--color-brand);
		background: color-mix(in srgb, var(--color-surface-elevated) 80%, transparent);
	}

	.contact-links--header .contact-links__icon :global(svg) {
		width: 1.05rem;
		height: 1.05rem;
	}

	.contact-links__item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		min-width: 2.75rem;
		min-height: 2.75rem;
		padding: 0.55rem;
		border-radius: 0.45rem;
		border: 1px solid color-mix(in srgb, currentColor 22%, transparent);
		color: inherit;
		text-decoration: none;
		transition:
			transform 0.18s var(--ease-out),
			background 0.18s var(--ease-out),
			border-color 0.18s var(--ease-out);
	}

	.contact-links__item:hover {
		transform: translateY(-1px);
		background: color-mix(in srgb, currentColor 10%, transparent);
		border-color: color-mix(in srgb, currentColor 40%, transparent);
	}

	.contact-links__icon {
		display: grid;
		place-items: center;
		line-height: 0;
	}

	.contact-links__icon :global(svg) {
		display: block;
	}

	.contact-links__text {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: lowercase;
	}

	.contact-links--row {
		flex-direction: row;
		align-items: center;
	}

	.contact-links--stack {
		flex-direction: column;
		align-items: stretch;
		max-width: 14rem;
	}

	.contact-links--stack .contact-links__item {
		justify-content: flex-start;
		width: 100%;
	}

	.contact-links--stack .contact-links__text {
		text-transform: none;
		letter-spacing: 0.01em;
		font-size: 0.9rem;
		font-family: var(--font-display);
	}

	.contact-links--rail {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.contact-links--rail .contact-links__item {
		min-width: 3rem;
		min-height: 3rem;
	}

	.contact-links--spread {
		gap: 1rem;
	}

	.contact-links--spread .contact-links__item {
		min-width: 3.25rem;
		min-height: 3.25rem;
		padding: 0.7rem;
		border-radius: 0.55rem;
	}

	.contact-links--spread .contact-links__icon :global(svg) {
		width: 1.5rem;
		height: 1.5rem;
	}

	.contact-links--mono {
		gap: 0.5rem;
	}

	.contact-links--mono .contact-links__item {
		min-width: 0;
		padding: 0.4rem 0.65rem;
		border-radius: 0.25rem;
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
	}

	.contact-links--inline {
		margin-top: 1.25rem;
		gap: 0.5rem;
	}

	.contact-links--inline .contact-links__item {
		border-radius: 999px;
	}
</style>
