---
import type { Locale } from '../site.config';
import type { PortfolioContent } from '../content/types';
import { assetPath, localeHomePath } from '../lib/paths';
import { locales, siteConfig } from '../site.config';

type Props = {
	locale: Locale;
	content: PortfolioContent;
};

const { content } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={content.meta.description} />
<meta name="google" content="notranslate" />
<title>{content.meta.title}</title>
<link rel="icon" type="image/png" href={assetPath(siteConfig.brandLogo)} />
<link rel="canonical" href={new URL(Astro.url.pathname, siteConfig.siteUrl).href} />
{
	locales.map((l) => (
		<link rel="alternate" hreflang={l} href={new URL(localeHomePath(l), siteConfig.siteUrl).href} />
	))
}
<link rel="alternate" hreflang="x-default" href={new URL(localeHomePath('pt'), siteConfig.siteUrl).href} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700&family=Figtree:wght@400;600;700&family=Literata:opsz,wght@7..72,400;7..72,600;7..72,700&family=Outfit:wght@500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Space+Grotesk:wght@500;600;700&display=swap"
	rel="stylesheet"
/>
{
	import.meta.env.DEV && (
		<script is:inline>
			(() => {
				const FONTS = new Set(['outfit', 'space', 'bricolage']);
				const PALETTES = new Set(['mandril', 'slate', 'forest', 'noir', 'clay', 'ocean']);
				try {
					const savedFont = localStorage.getItem('portfolio:dev-fonts');
					document.documentElement.setAttribute(
						'data-fonts',
						savedFont && FONTS.has(savedFont) ? savedFont : 'outfit',
					);
					const savedPalette = localStorage.getItem('portfolio:dev-palette');
					document.documentElement.setAttribute(
						'data-palette',
						savedPalette && PALETTES.has(savedPalette) ? savedPalette : 'ocean',
					);
				} catch {
					document.documentElement.setAttribute('data-fonts', 'outfit');
					document.documentElement.setAttribute('data-palette', 'ocean');
				}
			})();
		</script>
	)
}
